TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
# Generate with: node ace generate:key
APP_KEY=
NODE_ENV=development

# --- Database -------------------------------------------------------------
# Local development: use the individual DB_* variables below (local PostgreSQL).
# Production (Railway): set DATABASE_URL only and leave DB_* empty.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=mpmweb
DB_SSL=false

# --- JWT authentication ---------------------------------------------------
JWT_SECRET=change-me-use-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Frontend origin (CORS) ----------------------------------------------
FRONTEND_URL=http://localhost:5173
DRIVE_DISK=fs